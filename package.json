{
  "name": "vaultshuffle-redesign",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 8766",
    "build": "next build",
    "start": "next start -p 8766",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run build",
    "catalogue:fetch-top": "node scripts/catalogue/fetch-steamspy-top.mjs",
    "catalogue:build-seed": "node scripts/catalogue/build-seed-sql.mjs",
    "catalogue:import-durations": "node scripts/catalogue/import-duration-estimates.mjs",
    "igdb:lookup": "node --experimental-strip-types scripts/igdb/lookup.ts",
    "duration:admin": "node --experimental-strip-types scripts/igdb/admin.ts",
    "test:duration": "node --experimental-strip-types --test supabase/functions/_shared/igdb-duration-provider.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.10",
    "posthog-js": "^1.181.0",
    "posthog-node": "^4.3.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
